{
  "name": "dynamic-workflow-automation-backend",
  "version": "1.0.0",
  "description": "Backend for the Dynamic Workflow Automation System",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "worker:dev": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "test": "jest --runInBand"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "ajv": "^8.17.1",
    "bullmq": "^5.13.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "dynamic-workflow-automation": "file:..",
    "express": "^4.21.1",
    "ioredis": "^5.4.1",
    "jexl": "^2.3.0",
    "prisma": "^5.22.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/jexl": "^2.3.4",
    "@types/node": "^22.7.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "fast-check": "^3.22.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
